  <property name="styleSheet">
   <string notr="true">

QMainWindow {
    background-color: #f0f2f5;
}

/* --- GroupBox：白底 + 浅灰边框 + 圆角 --- */
QGroupBox {
    background-color: #ffffff;
    border: 1px solid #d0d5dd;
    border-radius: 6px;
    margin-top: 10px;
    font-weight: bold;
    padding-top: 8px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 4px;
    color: #1f2937;
}

/* --- 图像 QLabel：深灰背景 + 文本居中 --- */
QLabel#lblViewOriginal,
QLabel#lblViewSpectrum,
QLabel#lblViewFlatness {
    background-color: #2d2d2d;
    color: #9ca3af;
    qproperty-alignment: AlignCenter;
    border: 1px solid #d0d5dd;
    border-radius: 4px;
    min-height: 150px;
}

/* --- 参数显示 QLabel --- */
QGroupBox#groupParams QLabel {
    background: transparent;
    color: #374151;
}

/* --- 通信状态 QLabel --- */
QGroupBox#groupComm QLabel {
    background: transparent;
    color: #374151;
}

/* --- 日志框：深色背景 + 浅色等宽字体 --- */
QPlainTextEdit#plainTextEditLog {
    background-color: #1e1e2e;
    color: #cdd6f4;
    font-family: "Consolas", "Courier New", monospace;
    font-size: 9pt;
    border: 1px solid #313244;
    border-radius: 4px;
    selection-background-color: #45475a;
}

/* --- 通用 QPushButton 样式 --- */
QPushButton {
    color: #ffffff;
    border: none;
    border-radius: 5px;
    padding: 6px 12px;
    font-size: 9pt;
    font-weight: bold;
}

/* --- 开始检测：绿色 --- */
QPushButton#btnStart {
    background-color: #22c55e;
}
QPushButton#btnStart:hover {
    background-color: #16a34a;
}
QPushButton#btnStart:pressed {
    background-color: #15803d;
}
QPushButton#btnStart:disabled {
    background-color: #86efac;
}

/* --- 停止检测：红色 --- */
QPushButton#btnStop {
    background-color: #ef4444;
}
QPushButton#btnStop:hover {
    background-color: #dc2626;
}
QPushButton#btnStop:pressed {
    background-color: #b91c1c;
}
QPushButton#btnStop:disabled {
    background-color: #fca5a5;
}

/* --- 浏览 / 观察ROI/历史查询：蓝灰 --- */
QPushButton#btnBrowse,
QPushButton#btnObserveRoi,
QPushButton#btnQueryHistory {
    background-color: #6366f1;
}
QPushButton#btnBrowse:hover,
QPushButton#btnObserveRoi:hover,
QPushButton#btnQueryHistory:hover {
    background-color: #4f46e5;
}
QPushButton#btnBrowse:pressed,
QPushButton#btnObserveRoi:pressed,
QPushButton#btnQueryHistory:pressed {
    background-color: #4338ca;
}

/* --- 勾选状态（checkable 按钮）--- */
QPushButton#btnObserveRoi:checked {
    background-color: #f59e0b;
}
QPushButton#btnObserveRoi:checked:hover {
    background-color: #d97706;
}

/* --- QComboBox / QLineEdit --- */
QComboBox, QLineEdit {
    background-color: #ffffff;
    border: 1px solid #d0d5dd;
    border-radius: 4px;
    padding: 4px 8px;
    color: #1f2937;
}
QComboBox:hover, QLineEdit:hover {
    border-color: #6366f1;
}

/* --- QSlider --- */
QSlider::groove:horizontal {
    background: #e5e7eb;
    height: 4px;
    border-radius: 2px;
}
QSlider::handle:horizontal {
    background: #6366f1;
    width: 14px;
    height: 14px;
    margin: -5px 0;
    border-radius: 7px;
}
QSlider::sub-page:horizontal {
    background: #818cf8;
    border-radius: 2px;
}

/* --- QStatusBar --- */
QStatusBar {
    background-color: #e5e7eb;
    color: #374151;
    border-top: 1px solid #d0d5dd;
    font-size: 9pt;
}
