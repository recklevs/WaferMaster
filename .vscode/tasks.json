{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure (vscode)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "vscode"
            ],
            "options": {
                "cwd": "${workspaceFolder}/WaferMaster"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake: Build Debug (vscode)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "vscode-debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}/WaferMaster"
            },
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "CMake: Configure (vscode)"
        },
        {
            "label": "CMake: Build Release (vscode)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "vscode-release"
            ],
            "options": {
                "cwd": "${workspaceFolder}/WaferMaster"
            },
            "problemMatcher": "$msCompile",
            "dependsOn": "CMake: Configure (vscode)"
        }
    ]
}
